# SOSReport RCA Engine 配置文件
# 复制此文件为 .env 并填入真实的配置值
# cp .env.example .env

# DeepSeek API Key（必填，在 https://platform.deepseek.com/api_keys 获取）
DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek API 地址（默认即可）
DEEPSEEK_API_URL=https://api.deepseek.com

# LLM 模型（deepseek-chat=通用模型, deepseek-reasoner=推理模型，RCA 推荐后者）
LLM_MODEL=deepseek-reasoner

# Web 服务监听地址和端口
WEB_HOST=127.0.0.1
WEB_PORT=8080

# 默认时间窗口（故障时间点前后各多少分钟）
DEFAULT_MARGIN=15
